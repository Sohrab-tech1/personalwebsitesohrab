---
interface Props {
  locale: 'sv' | 'en'
}

const { locale } = Astro.props
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center justify-between h-14">
      <a href={`/${locale}/`} class="text-lg font-semibold text-gray-900">
        sohrab.se
      </a>
      <nav class="flex items-center gap-1 text-sm" aria-label="Språkväljare">
        <a
          href="/sv/"
          class:list={[
            'px-2 py-1 rounded transition-colors',
            locale === 'sv' ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-700',
          ]}
        >
          SV
        </a>
        <span class="text-gray-300">/</span>
        <a
          href="/en/"
          class:list={[
            'px-2 py-1 rounded transition-colors',
            locale === 'en' ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-700',
          ]}
        >
          EN
        </a>
      </nav>
    </div>
  </div>
</header>
