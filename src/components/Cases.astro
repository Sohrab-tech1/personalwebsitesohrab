---
import { t, type Locale } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props

const caseKeys = ['medis', 'parklife', 'techarena', 'lkr']
---

<section id="cases" class="py-24">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12 text-gray-900">
      {t(locale, 'cases.title')}
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      {caseKeys.map((key) => (
        <div class="bg-white rounded-xl p-8 border border-gray-100 hover:border-gray-200 transition-colors">
          <span class="text-sm text-gray-400 uppercase tracking-wide">
            {t(locale, `cases.items.${key}.type`)}
          </span>
          <h3 class="text-xl font-semibold text-gray-900 mt-2 mb-3">
            {t(locale, `cases.items.${key}.title`)}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t(locale, `cases.items.${key}.description`)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
