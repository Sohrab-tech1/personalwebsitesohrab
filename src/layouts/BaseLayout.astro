---
import '@fontsource/inter/400.css'
import '@fontsource/inter/500.css'
import '@fontsource/inter/600.css'
import '@fontsource/inter/700.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  locale: 'sv' | 'en'
  title?: string
}

const { locale, title = 'Sohrab Fadai — PR, webb och AI från Stockholm' } = Astro.props
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Jag hjälper företag att synas. PR, webb och AI från Stockholm." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Jag hjälper företag att synas. PR, webb och AI från Stockholm." />
    <meta property="og:url" content="https://sohrab.se" />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <slot name="head" />
  </head>
  <body class="antialiased text-gray-900 bg-white font-sans">
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>
